    </caravanTraderKinds>
    <baseTraderKinds>
      <li>Base_Neolithic_Standard</li>
    </baseTraderKinds>
    <pawnGroupMakers>
      <li>
        <kindDef>Peaceful</kindDef>
        <options>
          <Tribal_Warrior>1</Tribal_Warrior>
        </options>
      </li>
      <li>
        <kindDef>Settlement</kindDef>
        <options>
          <Tribal_Warrior>7</Tribal_Warrior>
          <Tribal_Archer>10</Tribal_Archer>
          <Tribal_Hunter>10</Tribal_Hunter>
        </options>
      </li>
      <li>
        <kindDef>Trader</kindDef>
        <traders>
          <Tribal_Trader>1</Tribal_Trader>
        </traders>
        <carriers>
          <Muffalo>3</Muffalo>
        </carriers>
        <guards>
          <Tribal_Warrior>3</Tribal_Warrior>
          <Tribal_Archer>3</Tribal_Archer>
        </guards>
      </li>
    </pawnGroupMakers>
  </FactionDef>


<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <FactionDef ParentName="FactionBase" Name="Torch_AncestorsBase" Abstract="True">
    <label>ancestral home</label>
    <description>The settlement of your colony's previous generation.</description>
    <pawnSingular>ancestor</pawnSingular>
    <pawnsPlural>ancestors</pawnsPlural>
    <leaderTitle>elder</leaderTitle>
    <settlementTexturePath>World/WorldObjects/DefaultSettlement</settlementTexturePath>
    <factionIconPath>World/WorldObjects/Expanding/Town</factionIconPath>
    <listOrderPriority>100</listOrderPriority>
    <settlementGenerationWeight>0</settlementGenerationWeight>
    <requiredCountAtGameStart>0</requiredCountAtGameStart>
    <permanentEnemy>false</permanentEnemy>
    <autoFlee>true</autoFlee>
    <canMakeRandomly>false</canMakeRandomly>
    <humanlikeFaction>true</humanlikeFaction>
    <hidden>true</hidden>
    <maxPawnCostPerTotalPointsCurve>
      <points>
        <li>(0,35)</li>
        <li>(70, 50)</li>
        <li>(700, 100)</li>
        <li>(1300, 150)</li>
        <li>(100000, 10000)</li>
      </points>
    </maxPawnCostPerTotalPointsCurve>
    <factionNameMaker>NamerFactionOutlander</factionNameMaker>
    <settlementNameMaker>NamerSettlementOutlander</settlementNameMaker>
    <canRequestTraders>true</canRequestTraders>
    <canRequestMilitaryAid>true</canRequestMilitaryAid>
    <backstoryFilters>
      <li>
        <categories>
          <li>Offworld</li>
          <li>Civil</li>
        </categories>
      </li>
    </backstoryFilters>
  </FactionDef>

  <FactionDef ParentName="Torch_AncestorsBase">
    <defName>Torch_Ancestors_Neolithic</defName>
